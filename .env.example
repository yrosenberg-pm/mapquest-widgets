# Copy to ".env.local" and fill in values. Do not commit .env.local.

# MapQuest (geocoding, tiles, search — used by /api/mapquest and NEXT_PUBLIC_ for the client)
NEXT_PUBLIC_MAPQUEST_API_KEY=
MAPQUEST_API_KEY=

# Mapillary — server routes (e.g. Neighborhood Score proxy) if used
MAPILLARY_ACCESS_TOKEN=

# Mapillary — browser-only (Mapillary Street View showcase widget + client Graph API)
# Get a client access token at https://www.mapillary.com/dashboard/developers
NEXT_PUBLIC_MAPILLARY_ACCESS_TOKEN=

# Legacy / OAuth (optional)
MAPILLARY_CLIENT_ID=
MAPILLARY_CLIENT_SECRET=
MAPILLARY_AUTH_URL=
